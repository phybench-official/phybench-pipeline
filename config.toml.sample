# PhyBench Pipeline Configuration
# Copy this file to 'config.toml' and update with your actual values
# You may also use --config-file to specify other config file paths.

# ------------------------------- providers ------------------------------- #

# API provider configurations. api_caller will auto-select based on model name.
[[providers]]
# A unique name for this provider.
name = "openai"
base_url = "https://api.openai.com/v1"
# It's recommended to set the API key as an environment variable.
api_key = "your_api_key_here"
# Models available through this provider.
models = ["gpt-4o", "gpt-3.5-turbo"]

[[providers]]
name = "local_ollama"
base_url = "http://localhost:11434/v1"
# For local models, provide a non-empty string.
api_key = "your_api_key_here"
models = ["llama3", "phi3"]


# -------------------------------- api_caller -------------------------------- #
[api_caller.model]
# Default model for API calls.
model = "gpt-4o"
# Keywords for OpenAI 'o' series models (for 'reasoning_effort').
openai_o_model_keywords = [
    "o3-mini",
    "o3 (high)",
    "o3-high",
    "o3-mini (high)",
    "o4-mini",
    "o4-mini (high)",
    "o1",
    "o1-preview-all",
]

[api_caller.paths]
# Directory for input JSON files.
input_dir = "data/ground_truth"
# Input problems filename (JSON).
input_file = "test.json"
# Directory for output JSON files.
output_dir = "data/model_solutions"
# Output filename template for model solutions.
# Placeholders: {input_file}, {model}
output_file = "{input_file}_{model}"

[api_caller.execution]
# Number of concurrent API calls.
num_consumers = 10
# API call timeout (seconds).
chat_timeout = 1200
# Number of times to run each problem.
repeat_count = 1
# Max retries for failed API calls.
max_retries = 5
# Max items in the task queue.
max_task_queue_size = 100

[api_caller.prompt]
# User prompt prefix for the API call.
prefix = """You are a physics expert. Carefully read the following question and provide a clear, step-by-step solution leading clearly to the final answer.
Your final answer must be enclosed strictly within a single \boxed{} command.
The final answer must be a single, fully simplified, and directly parseable LaTeX expression.
Do NOT include integral symbol, multiple lines, piecewise cases, summation symbols, or textual explanations inside the boxed expression.
Use standard LaTeX conventions rigorously."""
# User prompt suffix for the API call.
suffix = "Please provide the solution in LaTeX format, ensuring that the final boxed answer is clear and concise."


# -------------------------------- evaluation -------------------------------- #
[evaluation.paths]
# Directory for input ground truth JSON files.
gt_dir = "data/ground_truth"
# Ground truth filename template (without path; with or without .json)
# Placeholders: {api_caller_input_file}, {api_caller_model}, {api_caller_output_file}
gt_file = "test.json"
# Directory for input model solution JSON files.
model_answers_dir = "data/model_solutions"
# Model answers filename template (without path; with or without .json)
# Placeholders: Same as gt_file above
model_answers_file = "test_gpt-4o.json"
# Directory for output evaluation results JSON files.
output_dir = "data/evaluation_results"
# Output filename template for evaluation results (without path; with or without .json)
# Placeholders: {gt_file}, {model_answers_file}, {api_caller_input_file}, {api_caller_model}, {api_caller_output_file}
output_file = "test.json"

[evaluation.eed]
# Base score before distance penalty (0-100).
initial_score = 60
# Scaling factor for distance penalty.
scoring_slope = 100
# Cost for inserting a node in the expression tree
insert_cost = { number = 1, symbol = 1, operator = 1, function = 1 }
# Cost for deleting a node in the expression tree
delete_cost = { number = 1, symbol = 1, operator = 1, function = 1 }
# Cost for updating a node in the expression tree
update_cost = { number = 1, symbol = 1, operator = 1, function = 1 }
# Cost for changing node type (e.g., from a number to a symbol).
change_type_cost = 1
# Minimum subtree size for cluster discount.
bar_size = 5
# Discount slope for large subtrees.
discount_slope = 0.6
# Time limit for simplifying expressions (seconds).
simplify_time_limit = 30
# Time limit for checking expression equality (seconds).
equals_time_limit = 10

[evaluation.execution]
# Number of CPU cores for parallel processing (0 = auto-detect).
num_processes = 0
# Problem IDs to skip during evaluation.
skip_problem_ids = [108]


# -------------------------------- logging -------------------------------- #
[logging]
# Directory for log files.
log_dir = "logs"
# Log filename.
# Placeholders: {gt_file}, {api_caller_input_file}
log_file = "test.json"
# Log level for console output (TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL)
console_level = "INFO"
# Log level for file output (TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL)
file_level = "DEBUG"
