# PhyBench Pipeline Configuration
# Copy this file to 'config.toml' and update with your actual values
# You may also use --config-file to specify other config file paths.

# ------------------------------- providers ------------------------------- #

# Define a list of API providers. The api_caller will automatically select the
# correct provider based on the model name you pass via the --model argument.
[[providers]]
# A unique name for this provider configuration
name = "openai"
base_url = "https://api.openai.com/v1"
# It's recommended to set the API key as an environment variable, e.g.,
# export PROVIDER_OPENAI_API_KEY="your_sk-..."
api_key = "your_api_key_here"
# A list of models that this provider configuration applies to.
models = ["gpt-4o", "gpt-3.5-turbo"]

[[providers]]
name = "local_ollama"
base_url = "http://localhost:11434/v1"
# For local models that don't require a key, provide a non-empty string.
api_key = "your_api_key_here"
models = ["llama3", "phi3"]


# -------------------------------- api_caller -------------------------------- #
[api_caller.model]
# Model to use if not specified by --model argument
model = "gpt-4o"
# Comma-separated list of OpenAI 'o' series model keywords (for 'reasoning_effort')
openai_o_model_keywords = [
    "o3-mini",
    "o3 (high)",
    "o3-high",
    "o3-mini (high)",
    "o4-mini",
    "o4-mini (high)",
    "o1",
    "o1-preview-all",
]

[api_caller.paths]
# Directory containing input JSON files
input_dir = "data/ground_truth"
# Input filename template (without path, with or without .json extension)
input_file = "test.json"
# Directory to save output JSON files (individual model solution files)
output_dir = "data/model_solutions"
# Output filename template (without path, with or without .json extension)
# Available placeholders:
#   {input_file} - Input filename without extension (e.g., "test")
#   {model}      - Model name with special chars sanitized (e.g., "gpt-4o")
output_file = "{input_file}_{model}"

[api_caller.execution]
# Number of consumer threads/tasks
num_consumers = 10
# API call timeout in seconds
chat_timeout = 1200
# Number of times to process each problem
repeat_count = 1
# Max retries for a failed API call for a single task
max_retries = 5
# Max items in the task_queue
max_task_queue_size = 100


# -------------------------------- evaluation -------------------------------- #
[evaluation.paths]
# Directory containing ground truth files
gt_dir = "data/ground_truth"
# Ground truth filename template (without path, with or without .json extension)
# Available placeholders:
#   {api_caller_input_file}  - Input filename from API caller (e.g., "test")
#   {api_caller_model}       - Model name from API caller (e.g., "gpt-4o")
#   {api_caller_output_file} - Output filename from API caller (e.g., "test_gpt-4o")
gt_file = "test.json"
# Directory containing model solution files
model_answers_dir = "data/model_solutions"
# Model answers filename template (without path, with or without .json extension)
# Available placeholders: Same as gt_file above
model_answers_file = "test_gpt-4o.json"
# Directory to save evaluation results
output_dir = "data/evaluation_results"
# Output filename template (without path, with or without .json extension)
# Available placeholders:
#   {gt_file}                - Ground truth filename without extension
#   {model_answers_file}     - Model answers filename without extension
#   {api_caller_input_file}  - Input filename from API caller
#   {api_caller_model}       - Model name from API caller
#   {api_caller_output_file} - Output filename from API caller
output_file = "test.json"

[evaluation.eed]
# Base score assigned before distance penalty (higher = more lenient, range: 0-100)
initial_score = 60
# Scaling factor for expression distance penalty (higher = steeper penalty curve)
scoring_slope = 100
# Cost for inserting a node in the expression tree
insert_cost = { number = 1, symbol = 1, operator = 1, function = 1 }
# Cost for deleting a node in the expression tree
delete_cost = { number = 1, symbol = 1, operator = 1, function = 1 }
# Cost for updating a node in the expression tree
update_cost = { number = 1, symbol = 1, operator = 1, function = 1 }
# Cost for changing the type of a node (e.g., from a number to a symbol)
change_type_cost = 1
# The minimum size of a subtree to trigger a cluster discount
bar_size = 5
# The slope of the discount for large subtrees
discount_slope = 0.6
# Time limit for simplifying expressions in seconds
simplify_time_limit = 30
# Time limit for checking equality of expressions in seconds
equals_time_limit = 10

[evaluation.execution]
# Number of CPU cores to use (0 = auto-detect)
num_processes = 0


# -------------------------------- logging -------------------------------- #
[logging]
# Directory to save log files
log_dir = "logs"
# Log filename template
# Available placeholders:
#   {gt_file}                - Ground truth filename without extension
#   {api_caller_input_file}  - Input filename from API caller
log_file = "test.json"
# Log level for console output (TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL)
console_level = "INFO"
# Log level for file output (TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL)
file_level = "DEBUG"
