; Sample configuration file
; Copy this to config.ini and update with your actual values

; -------------------------------- api_caller -------------------------------- ;
[api_caller.api]
# Base URL for the API endpoint (OpenAI-compatible API server)
base_url = https://api.gpt.ge/v1
# API key for authentication with the language model service
api_key = your_api_key_here

[api_caller.model]
# Model to use if not specified by --model argument
model = gpt-4o
# Comma-separated list of OpenAI 'o' series model keywords (for 'reasoning_effort')
openai_o_model_keywords = o3-mini, o3 (high), o3-high, o3-mini (high), o4-mini, o4-mini (high), o1, o1-preview-all

[api_caller.paths]
# Directory containing input JSON files
input_dir = data/ground_truth
# Input filename (without path, with or without .json extension)
input_file = test.json
# Directory to save output JSON files (individual model solution files)
output_dir = data/model_solutions
# Output filename template
# Available placeholders:
#   {input_file} - Input filename without extension (e.g., "test")
#   {model}      - Model name with special chars sanitized (e.g., "gpt-4o")
output_file = {input_file}_{model}

[api_caller.execution]
# Number of consumer threads/tasks
num_consumers = 10
# API call timeout in seconds
chat_timeout = 1200
# Number of times to process each problem
repeat_count = 1
# Max retries for a failed API call for a single task
max_retries = 5
# Max items in the task_queue
max_task_queue_size = 100


; -------------------------------- evaluation -------------------------------- ;
[evaluation.paths]
# Directory containing ground truth files
gt_dir = data/ground_truth
# Ground truth filename (without path, with or without .json extension)
# Available placeholders:
#   {api_caller_input_file}  - Input filename from API caller (e.g., "test")
#   {api_caller_model}       - Model name from API caller (e.g., "gpt-4o")
#   {api_caller_output_file} - Output filename from API caller (e.g., "test_gpt-4o")
gt_file = {api_caller_input_file}
# Directory containing model solution files
model_answers_dir = data/model_solutions
# Model answers filename (without path, with or without .json extension)
# Available placeholders: Same as gt_file above
model_answers_file = {api_caller_output_file}
# Directory to save evaluation results
output_dir = data/evaluation_results
# Output filename template
# Available placeholders:
#   {gt_file}                - Ground truth filename without extension
#   {model_answers_file}     - Model answers filename without extension
#   {api_caller_input_file}  - Input filename from API caller
#   {api_caller_model}       - Model name from API caller
#   {api_caller_output_file} - Output filename from API caller
output_file = {api_caller_input_file}
# Directory to save log files
log_dir = logs
# Log filename template
# Available placeholders: Same as output_file above
log_file = {api_caller_input_file}

[evaluation.scoring]
# Base score assigned before distance penalty (higher = more lenient, range: 0-100)
initial_score = 60
# Scaling factor for expression distance penalty (higher = steeper penalty curve)
scoring_slope = 100

[evaluation.execution]
# Number of CPU cores to use (0 = auto-detect)
num_processes = 0
